# .env.example — Template de variáveis de ambiente para o cérebro do Morfeu
#
# COMO USAR (no VPS srv1429674):
#   cp .env.example /root/.config/morfeu/morfeu.env
#   chmod 600 /root/.config/morfeu/morfeu.env
#   # Preencher os valores reais a partir do Vaultwarden (cofre.diegodiehl.com)
#
# Para carregar automaticamente no shell:
#   set -a; source /root/.config/morfeu/morfeu.env; set +a
#
# Em cron jobs:
#   0 */1 * * * . /root/.config/morfeu/morfeu.env && python3 /root/.openclaw/workspace/integrations/tldv/queue_processor.py >> ... 2>&1

# ─── Telegram ────────────────────────────────────────────────
# Bot token do Morfeu (obter em BotFather do Telegram)
TELEGRAM_TOKEN=

# Chat ID pessoal de Diego para alertas internos
TELEGRAM_CHAT_ID_DIEGO=8671853499

# ─── tl;dv ────────────────────────────────────────────────────
# API key para pipeline tl;dv (obter em https://tldv.io/app/settings → API)
TLDV_API_KEY=

# ─── OpenClaw Dashboard ──────────────────────────────────────
# Token de autenticação do dashboard (rotacionar se vazado)
OPENCLAW_TOKEN=

# ─── MiniMax / LLM ───────────────────────────────────────────
# API key primário do MiniMax (M2.5 Coding Plan Starter)
MINIMAX_API_KEY=

# Fallback Anthropic para P0 apenas
ANTHROPIC_API_KEY=

# ─── Trinks (agendamento de cabelo) ──────────────────────────
# Senha de Diego no Trinks — usada por trinks_booking.py
TRINKS_PASSWORD=

# ─── Google Workspace (gog / gcalcli) ────────────────────────
# Senha do keyring gogcli — lida de /root/.config/morfeu/secrets/gog_keyring_password
# Não definir aqui; usar o arquivo de senha.

# ─── Paths (não alterar em VPS) ──────────────────────────────
WORKSPACE=/root/.openclaw/workspace
MORFEU_LOG_DIR=/root/.openclaw/logs
