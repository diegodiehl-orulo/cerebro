# ──────────────────────────────────────────────────────────────────────────
# .env — segredos e overrides locais (NÃO versionar)
# Copie este arquivo para `.env` e preencha as chaves reais.
#
# A integração tl;dv carrega este arquivo automaticamente via
# integrations/tldv/config.py (load_dotenv) sem sobrescrever env vars
# já definidas no shell.
# ──────────────────────────────────────────────────────────────────────────

# Obrigatório: chave da API tl;dv (obter em https://tldv.io/app/api)
TLDV_API_KEY=

# Obrigatório para análise LLM (analyzer_v2.py, summarizer.py)
MINIMAX_API_KEY=

# Opcional: segredo para validar webhooks tl;dv (header x-tldv-signature)
TLDV_WEBHOOK_SECRET=

# Opcional: override do diretório raiz (default: detectado do __file__)
# CEREBRO_HOME=/home/user/cerebro

# Opcional: ajustes de pipeline
# TLDV_HTTP_TIMEOUT=30
# TLDV_LLM_TIMEOUT=90
# TLDV_RATE_LIMIT_PAUSE=5
# TLDV_MAX_RETRIES=3
# TLDV_MAX_CONSECUTIVE_ERRORS=5
# TLDV_PAGE_SIZE=50
# TLDV_WEBHOOK_PORT=18788

# Opcional: modelo LLM alternativo
# MINIMAX_MODEL=MiniMax-M2.5
# MINIMAX_URL=https://api.minimaxi.chat/v1/chat/completions
