{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "schema_kpi_source_file",
  "type": "object",
  "properties": {
    "metadata": {
      "type": "object",
      "properties": {
        "praca_id": { "type": "string" },
        "source": { "type": "string" }
      },
      "required": ["praca_id"]
    },
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "date": { "type": "string", "format": "date" },
          "mrr": { "type": ["number", "null"] },
          "corretores_ativos": { "type": ["integer", "null"] },
          "deals_criados": { "type": ["integer", "null"] }
        },
        "required": ["date"]
      }
    }
  },
  "required": ["metadata", "records"]
}
