{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "schema_kpi_data_validated",
  "type": "object",
  "properties": {
    "metadata": { "$ref": "#/definitions/metadata" },
    "kpis": {
      "type": "object",
      "properties": {
        "mrr": { "type": "number" },
        "corretores_ativos": { "type": "number" },
        "deals_criados": { "type": "number" }
      },
      "required": ["mrr", "corretores_ativos", "deals_criados"]
    }
  },
  "required": ["metadata", "kpis"],
  "definitions": {
    "metadata": {
      "type": "object",
      "properties": {
        "praca_id": { "type": "string" },
        "start_date": { "type": "string", "format": "date" },
        "end_date": { "type": "string", "format": "date" }
      },
      "required": ["praca_id", "start_date", "end_date"]
    }
  }
}
