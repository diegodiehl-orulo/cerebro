{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "schema_kpi_data_raw",
  "type": "object",
  "properties": {
    "metadata": {
      "type": "object",
      "properties": {
        "praca_id": { "type": "string" },
        "start_date": { "type": "string", "format": "date" },
        "end_date": { "type": "string", "format": "date" }
      },
      "required": ["praca_id", "start_date", "end_date"]
    },
    "kpis": {
      "type": "object",
      "properties": {
         "mrr": { "type": ["number", "null"] },
          "corretores_ativos": { "type": ["integer", "null"] },
          "deals_criados": { "type": ["integer", "null"] }
      }
    }
  },
  "required": ["metadata", "kpis"]
}
