{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "schema_sprint_results",
  "type": "object",
  "properties": {
    "praca_context": { "$ref": "schema_praca_context.json" },
    "sprint_period": {
      "type": "object",
      "properties": {
        "start_date": { "type": "string", "format": "date" },
        "end_date": { "type": "string", "format": "date" }
      },
      "required": ["start_date", "end_date"]
    },
    "kpis_validated": { "$ref": "schema_kpi_data_validated.json" },
    "deviations": {
      "type": "array",
      "items": { "$ref": "schema_kpi_deviation.json" }
    }
  },
  "required": ["praca_context", "sprint_period", "kpis_validated", "deviations"]
}
