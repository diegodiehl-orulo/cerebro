    "data": [
      {
        "startTime": 999,
        "endTime": 1000,
        "speaker": "Paulo Deitos",
        "text": "E aí João?"
      },
      {
        "startTime": 1000,
        "endTime": 1003,
        "speaker": "João Vitor Portes da Silva",
        "text": "Fala Paulo. Desculpa a demora meu cara, tava finalizando uma reunião aqui, por isso que eu não te atendi."
      },
      {
        "startTime": 1005,
        "endTime": 1006,
        "speaker": "Paulo Deitos",
        "text": "Tranquilo e o que a gente vai aparecer?"
      },
      {
        "startTime": 1007,
        "endTime": 1013,
        "speaker": "João Vitor Portes da Silva",
        "text": "Eu dei uma cobrada nele aqui já ele visualizou minha mensagem aqui não respondeu ainda. Vou dar uma ligada para ele já."
      },
      {
        "startTime": 1014,
        "endTime": 1017,
        "speaker": "Paulo Deitos",
        "text": "Ah se não deu né? Já tô há 20 minutos aqui esperando."
      },
      {
        "startTime": 1018,
        "endTime": 1070,
        "speaker": "João Vitor Portes da Silva",
        "text": "Tá não não já vou ligar para ele já só um minutinho. O Paulo eu tentei ligar para ele aqui sem sucesso. Acho que vamos. Vamos remarcar aí para não ocupar o teu tempo aí."
      },
      {
        "startTime": 1071,
        "endTime": 1081,
        "speaker": "Paulo Deitos",
        "text": "É na verdade assim se o cara disser que vai aparecer nós saímos da sala, se tu voltar, se tu puder avisa que a gente entra nesse horário. Tá tranquilo."
      },
      {
        "startTime": 1081,
        "endTime": 1086,
        "speaker": "João Vitor Portes da Silva",
        "text": "Sim Sim Não eu liguei para ele aqui e vou vamos aguardar mais um pouco aí qualquer coisa eu te aviso."
      },
      {
        "startTime": 1086,
        "endTime": 1087,
        "speaker": "Paulo Deitos",
        "text": "Beleza, me avisa tchau."
      },
      {
        "startTime": 1087,
        "endTime": 1088,
        "speaker": "João Vitor Portes da Silva",
        "text": "Show valeu Paulo."
      }
    ]
