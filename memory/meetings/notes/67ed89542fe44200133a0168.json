{
  "structuredNotes": [
    {
      "segmentId": "67ed9428fe3a430013665d5f",
      "timestamp": 614,
      "text": "Base de lançamentos do Secovi sendo usada pela prefeitura para acompanhar política de urbanismo",
      "topicId": "67ed9428fe3a430013665d53"
    },
    {
      "segmentId": "67ed9428fe3a430013665d5a",
      "timestamp": 717,
      "text": "Órulo possui aproximadamente 90.000 unidades de mercado primário em São Paulo",
      "topicId": "67ed9428fe3a430013665d52"
    },
    {
      "segmentId": "67ed9428fe3a430013665d5b",
      "timestamp": 815,
      "text": "Cerca de 40% do estoque de unidades imobiliárias em São Paulo têm atualização diária pela Órulo",
      "topicId": "67ed9428fe3a430013665d52"
    },
    {
      "segmentId": "67ed9428fe3a430013665d5c",
      "timestamp": 863,
      "text": "Unidade individual é a base do banco de dados da Órulo, com características específicas",
      "topicId": "67ed9428fe3a430013665d52"
    },
    {
      "segmentId": "67ed9428fe3a430013665d5d",
      "timestamp": 948,
      "text": "Metodologia da Órulo foca em acompanhar movimentação de cada unidade imobiliária",
      "topicId": "67ed9428fe3a430013665d52"
    },
    {
      "segmentId": "67ed9428fe3a430013665d5e",
      "timestamp": 1034,
      "text": "Órulo possui entre 90-100 mil unidades no município de São Paulo",
      "topicId": "67ed9428fe3a430013665d52"
    },
    {
      "segmentId": "67ed9428fe3a430013665d60",
      "timestamp": 1219,
      "text": "Discutir dados de lançamentos imobiliários a partir de 2 dormitórios em São Paulo",
      "topicId": "67ed9428fe3a430013665d53"
    },
    {
      "segmentId": "67ed9428fe3a430013665d61",
      "timestamp": 1343,
      "text": "Estoque atual de São Paulo: 85.000 unidades e 62 bilhões de VGV",
      "topicId": "67ed9428fe3a430013665d53"
    },
    {
      "segmentId": "67ed9428fe3a430013665d62",
      "timestamp": 1471,
      "text": "70.000 unidades disponíveis para lançamentos a partir de março de 2022",
      "topicId": "67ed9428fe3a430013665d53"
    },
    {
      "segmentId": "67ed9428fe3a430013665d55",
      "timestamp": 1526,
      "text": "Celso propõe período de 1 semana para conhecer sistema da Órulo",
      "topicId": "67ed9428fe3a430013665d51"
    },
    {
      "segmentId": "67ed9428fe3a430013665d56",
      "timestamp": 1924,
      "text": "Avaliar diferenças entre pesquisas e dados da Secovi-SP e Órulo",
      "topicId": "67ed9428fe3a430013665d51"
    },
    {
      "segmentId": "67ed9428fe3a430013665d63",
      "timestamp": 2192,
      "text": "Diego sugere parceria para fortalecer dados e informações do mercado imobiliário",
      "topicId": "67ed9428fe3a430013665d54"
    },
    {
      "segmentId": "67ed9428fe3a430013665d64",
      "timestamp": 2296,
      "text": "Integração com imobiliárias será gratuita pela Órulo",
      "topicId": "67ed9428fe3a430013665d54"
    },
    {
      "segmentId": "67ed9428fe3a430013665d57",
      "timestamp": 2492,
      "text": "Felipe gerará relatórios para Edson, com objetivo de criar ambiente para negociações imobiliárias",
      "topicId": "67ed9428fe3a430013665d51"
    },
    {
      "segmentId": "67ed9428fe3a430013665d58",
      "timestamp": 2534,
      "text": "Celso solicita análise da qualidade dos dados da API da empresa para 2024",
      "topicId": "67ed9428fe3a430013665d51"
    },
    {
      "segmentId": "67ed9428fe3a430013665d59",
      "timestamp": 2580,
      "text": "Parceria entre equipes será modelo ganha-ganha",
      "topicId": "67ed9428fe3a430013665d51"
    }
  ],
