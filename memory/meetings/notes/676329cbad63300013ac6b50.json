  "structuredNotes": [
    {
      "segmentId": "676332009123f700134be508",
      "timestamp": 215,
      "text": "Empresa expande carteira de clientes em imóveis, focando em distribuição via parceiros do mercado imobiliário.",
      "topicId": "676332009123f700134be501"
    },
    {
      "segmentId": "676332009123f700134be509",
      "timestamp": 349,
      "text": "Modelo de parceria remunera parceiros com 10% do valor recorrente de cada cliente indicado.",
      "topicId": "676332009123f700134be501"
    },
    {
      "segmentId": "676332009123f700134be50a",
      "timestamp": 735,
      "text": "Orla presente em principais praças: Porto Alegre, São Paulo, Curitiba, Goiânia, Rio de Janeiro e regiões nordestinas.",
      "topicId": "676332009123f700134be501"
    },
    {
      "segmentId": "676332009123f700134be50b",
      "timestamp": 852,
      "text": "Plataforma possui 4 mil incorporadoras cadastradas, com aproximadamente 2.500 ativas.",
      "topicId": "676332009123f700134be501"
    },
    {
      "segmentId": "676332009123f700134be50c",
      "timestamp": 1052,
      "text": "Cerca de 600 a 800 incorporadoras são clientes pagantes de produtos Orla.",
      "topicId": "676332009123f700134be501"
    },
    {
      "segmentId": "676332009123f700134be510",
      "timestamp": 1150,
      "text": "Plano de expansão inclui contratação de gerente de vendas para atuar em cidades não cobertas.",
      "topicId": "676332009123f700134be503"
    },
    {
      "segmentId": "676332009123f700134be50d",
      "timestamp": 1403,
      "text": "Empresa tem potencial para resolver problemas de atendimento em incorporadoras",
      "topicId": "676332009123f700134be502"
    },
    {
      "segmentId": "676332009123f700134be50f",
      "timestamp": 1441,
      "text": "Proposta de parceria pode aumentar receita dos clientes em até 33%",
      "topicId": "676332009123f700134be502"
    },
    {
      "segmentId": "676332009123f700134be505",
      "timestamp": 1604,
      "text": "Diego planeja ano estratégico focado em parcerias, com reunião inicial marcada para 7:30 da manhã.",
      "topicId": "676332009123f700134be500"
    },
    {
      "segmentId": "676332009123f700134be511",
      "timestamp": 1687,
      "text": "Equipe fará planejamento em chalé em Porto Alegre no início do próximo ano",
      "topicId": "676332009123f700134be504"
    },
    {
      "segmentId": "676332009123f700134be507",
      "timestamp": 1760,
      "text": "Importante escolher batalhas e estabelecer parcerias estratégicas",
      "topicId": "676332009123f700134be500"
    },
    {
      "segmentId": "676332009123f700134be50e",
      "timestamp": 1832,
      "text": "Solução da empresa facilita integração de sistemas para imobiliárias",
      "topicId": "676332009123f700134be502"
    },
    {
      "segmentId": "676332009123f700134be506",
      "timestamp": 1889,
      "text": "Objetivo para primeiro trimestre é estabelecer parceria próxima e estratégica",
      "topicId": "676332009123f700134be500"
    }
