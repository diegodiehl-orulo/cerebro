{
  "structuredNotes": [
    {
      "segmentId": "68111b15e2bdb90013b45ff1",
      "timestamp": 0,
      "text": "Reunião será apenas entre Felipe, Victor e Riccelly, sem a presença de Diego, Paulo ou Buzzi.",
      "topicId": "68111b15e2bdb90013b45fe3"
    },
    {
      "segmentId": "68111b15e2bdb90013b45fe7",
      "timestamp": 363,
      "text": "Blocco em negociação para captar aproximadamente 36 milhões com fundo suíço.",
      "topicId": "68111b15e2bdb90013b45fe0"
    },
    {
      "segmentId": "68111b15e2bdb90013b45fec",
      "timestamp": 683,
      "text": "Novo empreendimento em João Pessoa terá quatro torres, com foco comercial e localizado no Portal do Sol.",
      "topicId": "68111b15e2bdb90013b45fe1"
    },
    {
      "segmentId": "68111b15e2bdb90013b45fed",
      "timestamp": 865,
      "text": "Empreendimento será lançado em etapas, com primeira etapa prevista para dezembro deste ano.",
      "topicId": "68111b15e2bdb90013b45fe1"
    },
    {
      "segmentId": "68111b15e2bdb90013b45fee",
      "timestamp": 919,
      "text": "Obra da primeira etapa iniciará em julho do próximo ano, com duração estimada de 4 anos.",
      "topicId": "68111b15e2bdb90013b45fe1"
    },
    {
      "segmentId": "68111b15e2bdb90013b45fef",
      "timestamp": 1049,
      "text": "Planos alternativos de captação incluem Family Office, CRI e venda de unidades com desconto.",
      "topicId": "68111b15e2bdb90013b45fe2"
    },
    {
      "segmentId": "68111b15e2bdb90013b45ff0",
      "timestamp": 1156,
      "text": "Victor planeja captar capital em julho, com equipe estudando venda de unidades com desconto",
      "topicId": "68111b15e2bdb90013b45fe2"
    },
    {
      "segmentId": "68111b15e2bdb90013b45fe8",
      "timestamp": 1204,
      "text": "Fluxo de fundo suíço previsto para iniciar em setembro ou outubro",
      "topicId": "68111b15e2bdb90013b45fe0"
    },
    {
      "segmentId": "68111b15e2bdb90013b45fe9",
      "timestamp": 1267,
      "text": "Negociação com fundo prevê pagamento de 1-1.5% de juros mensais sobre valor acumulado",
      "topicId": "68111b15e2bdb90013b45fe0"
    },
    {
      "segmentId": "68111b15e2bdb90013b45fea",
      "timestamp": 1303,
      "text": "Acordo prevê divisão de lucro líquido: 50% para fundo, 50% para incorporadora",
      "topicId": "68111b15e2bdb90013b45fe0"
    },
    {
      "segmentId": "68111b15e2bdb90013b45feb",
      "timestamp": 1369,
      "text": "Fundo criará CNPJ no Brasil para gerenciar risco cambial",
      "topicId": "68111b15e2bdb90013b45fe0"
    },
    {
      "segmentId": "68111b15e2bdb90013b45fe4",
      "timestamp": 1529,
      "text": "Felipe irá discutir lançamento com Diego nos próximos dias",
      "topicId": "68111b15e2bdb90013b45fdf"
    },
    {
      "segmentId": "68111b15e2bdb90013b45fe5",
      "timestamp": 1565,
      "text": "Victor confirma possibilidade de pesquisar family offices para potencial investimento",
      "topicId": "68111b15e2bdb90013b45fdf"
    },
    {
      "segmentId": "68111b15e2bdb90013b45fe6",
      "timestamp": 1656,
      "text": "Riccelly irá passar documentos para Felipe e Diego analisarem",
      "topicId": "68111b15e2bdb90013b45fdf"
