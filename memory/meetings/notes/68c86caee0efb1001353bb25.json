    {
      "segmentId": "68c8740ff394d70013e758d4",
      "timestamp": 1176,
      "text": "Processo de engajamento com novos contatos de incorporadoras será adaptado.",
      "topicId": "68c8740ff394d70013e758c8"
    },
    {
      "segmentId": "68c8740ff394d70013e758ce",
      "timestamp": 1370,
      "text": "Equipe deve avisar Closer diretamente em caso de problemas de cadastro ou atividades pendentes",
