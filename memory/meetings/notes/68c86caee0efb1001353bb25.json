    },
    {
      "segmentId": "68c8740ff394d70013e758d2",
      "timestamp": 752,
      "text": "Time precisará aprimorar modelo de prospecção para crescer em novas praças.",
      "topicId": "68c8740ff394d70013e758c8"
    },
    {
      "segmentId": "68c8740ff394d70013e758d3",
      "timestamp": 797,
      "text": "Necessário corrigir processos no Bitrix sem improvisar.",
